{
  "name": "shared-2048-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop app wrapper for the 2048 web app",
  "main": "main.js",
  "author": "hayoungos",
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "electron": "^32.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "io.github.hayoungos.shared2048",
    "productName": "2048",
    "files": [
      "main.js",
      "preload.js"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
